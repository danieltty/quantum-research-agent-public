{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/qra-public/run_manifest.schema.json",
  "title": "QRA Public Run Manifest",
  "type": "object",
  "required": [
    "run_id",
    "artifact_status",
    "source_type",
    "created_at",
    "pipeline_mode",
    "input_files",
    "outputs",
    "human_review_status"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_status": {
      "type": "string",
      "enum": ["sample", "demo", "sanitized_real_run", "template"]
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_mode": {
      "type": "string",
      "enum": ["public_demo", "production_sanitized", "template"]
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_status": {
      "type": "string",
      "enum": ["not_reviewed", "reviewed", "accepted", "rejected", "needs_followup"]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
