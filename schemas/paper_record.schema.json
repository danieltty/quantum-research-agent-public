{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/qra-public/paper_record.schema.json",
  "title": "QRA Public Paper Record",
  "type": "object",
  "required": [
    "paper_id",
    "title",
    "authors",
    "year",
    "source",
    "artifact_status"
  ],
  "properties": {
    "paper_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "year": {
      "type": "integer"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "artifact_status": {
      "type": "string",
      "enum": ["sample", "demo", "sanitized_real_run", "template"]
    },
    "url": {
      "type": "string"
    },
    "abstract": {
      "type": "string"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
